# ARIA Voice - Configuração

# Hugging Face (chat + TTS de fallback) - obrigatório
# Obtenha em: https://huggingface.co/settings/tokens
HF_TOKEN=seu_token_aqui

# Opcional: ElevenLabs (TTS premium, usado com prioridade)
# ELEVENLABS_API_KEY=

PORT=3000

# Login do app (tela de entrada)
AUTH_USER=aria
AUTH_PASS=troque_esta_senha
# AUTH_SECRET=segredo_para_assinar_tokens

# Restringe CORS a uma origem específica em produção (padrão: * )
# ALLOWED_ORIGIN=https://seu-dominio.com
