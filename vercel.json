{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(sw\\.js|app\\.js|manifest\\.json|.*\\.html)",
      "dest": "/public/$1",
      "headers": {
        "Cache-Control": "no-cache, must-revalidate"
      }
    },
    {
      "src": "/(.*\\.(js|css|svg|png|ico|json|mp3))",
      "dest": "/public/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/app",
      "dest": "/public/index.html",
      "headers": {
        "Cache-Control": "no-cache, must-revalidate"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/public/landing.html",
      "headers": {
        "Cache-Control": "no-cache, must-revalidate"
      }
    }
  ]
}
